{
	"name": "notebooklm",
	"version": "0.1.0",
	"description": "NotebookLM wrapper with better UI/UX",
	"private": true,
	"packageManager": "bun@1.2.4",
	"workspaces": [
		"./server",
		"./client",
		"./shared"
	],
	"scripts": {
		"dev": "turbo dev",
		"dev:client": "turbo dev --filter=client",
		"dev:server": "turbo dev --filter=server",
		"build": "turbo build",
		"build:client": "turbo build --filter=client",
		"build:server": "turbo build --filter=server",
		"lint": "turbo lint",
		"type-check": "turbo type-check",
		"test": "turbo test",
		"postinstall": "turbo build --filter=shared --filter=server"
	},
	"devDependencies": {
		"bun-types": "latest",
		"turbo": "^2.6.3"
	},
	"peerDependencies": {
		"typescript": "^5.8.3"
	}
}
