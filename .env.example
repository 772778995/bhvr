# OpenAI compatible model settings for quick book finder
OPENAI_BASE_URL=https://your-openai-compatible-host/v1
OPENAI_TOKEN=your-openai-compatible-token
OPENAI_MODEL=your-model-name

# Optional metadata bridge for WeRead links and public rating fields
BOOK_METADATA_BASE_URL=https://your-metadata-bridge-host
BOOK_METADATA_API_KEY=your-metadata-api-key
BOOK_METADATA_TIMEOUT_MS=3000

# ---------------------------------------------------------------------------
# NotebookLM Docker / headless server authentication
# ---------------------------------------------------------------------------
# Option A: mount the storage-state.json file and point to it
# NOTEBOOKLM_STORAGE_STATE_PATH=/run/secrets/notebooklm-storage-state

# Option B: supply the file content as base64 (e.g. via Docker secret or env)
# Generate with: base64 -w0 ~/.notebooklm/profiles/default/storage-state.json
# NOTEBOOKLM_STORAGE_STATE_JSON_B64=<base64-encoded content>

# If both are set, the base64 content is written to the PATH location (only if
# the target file does not already exist, to avoid overwriting a refreshed session).

# ---------------------------------------------------------------------------
# Re-authentication & alerting (for headless / server deployments)
# ---------------------------------------------------------------------------
# Protect the manual reauth endpoint (POST /api/auth/reauth).
# If not set, the endpoint returns 503 and is effectively disabled.
# ADMIN_SECRET=your-strong-secret-here

# Optional: POST webhook URL to call when auth enters reauth_required state.
# If not configured, a structured WARN log is emitted instead.
# REAUTH_WEBHOOK_URL=https://your-webhook.example.com/notebooklm-alert

