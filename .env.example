# OpenAI compatible model settings for quick book finder
OPENAI_BASE_URL=https://your-openai-compatible-host/v1
OPENAI_TOKEN=your-openai-compatible-token
OPENAI_MODEL=your-model-name

# Optional metadata bridge for WeRead links and public rating fields
BOOK_METADATA_BASE_URL=https://your-metadata-bridge-host
BOOK_METADATA_API_KEY=your-metadata-api-key
BOOK_METADATA_TIMEOUT_MS=3000
